# 静屿 — 环境变量示例
# 复制为 .env 后按需修改
# 留空 = 用 [app/config.py] 里的默认值

# ─────────────────────────────────────────────────────────────
# 应用密钥（生产环境必须修改为随机长字符串）
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────
QI_SECRET_KEY=please-change-me-to-a-random-string-in-production

# ─────────────────────────────────────────────────────────────
# 数据库（SQLite 默认；将来换 MySQL 改这一行即可）
# ─────────────────────────────────────────────────────────────
QI_DATABASE_URL=sqlite:///./data/healing.db
# MySQL 示例:
# QI_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/healing?charset=utf8mb4

# ─────────────────────────────────────────────────────────────
# 服务监听
# 本机: 127.0.0.1:5000
# 服务器: 0.0.0.0:5000（再用 Nginx 反向代理到 80/443）
# ─────────────────────────────────────────────────────────────
QI_HOST=127.0.0.1
QI_PORT=5000

# ─────────────────────────────────────────────────────────────
# 调试模式
# 本地开发: true（详细错误信息、热重载友好）
# 生产环境: false（隐藏错误细节、不返回堆栈）
# ─────────────────────────────────────────────────────────────
QI_DEBUG=true

# ─────────────────────────────────────────────────────────────
# 日记加密的 PBKDF2 迭代次数
# 越高越安全越慢；200000 是 OWASP 2023 推荐值
# 改这个值会让旧用户解密失败（不要改！）
# ─────────────────────────────────────────────────────────────
QI_ENCRYPTION_ITERATIONS=200000

# ─────────────────────────────────────────────────────────────
# （可选）自定义 PID / 日志目录
# 宝塔面板一般在 /www/wwwroot/healing/{run,logs}
# ─────────────────────────────────────────────────────────────
# QI_RUN_DIR=/www/wwwroot/healing/run
# QI_LOG_DIR=/www/wwwroot/healing/logs

# ─────────────────────────────────────────────────────────────
# 秘密后台（默认隐藏入口 /admin）
# 首次启动会自动创建第一个管理员，密码随机生成并写入 logs/healing.log
# 强烈建议在 .env 里直接指定一个固定密码
# ─────────────────────────────────────────────────────────────
# QI_ADMIN_USERNAME=admin
# QI_ADMIN_PASSWORD=your-strong-admin-password-here
# QI_ADMIN_PATH_PREFIX=/admin        ← 改成自定义可让入口更隐蔽

# ─────────────────────────────────────────────────────────────
# AI 接入（NVIDIA NIM API，OpenAI 兼容）
# 申请: https://build.nvidia.com → 登录 → 拿 nvapi- 开头的 key
# 留空 = AI 功能禁用（树洞/鼓励语/治愈语/音乐推荐 都会返回"AI 暂时不在"提示）
# ─────────────────────────────────────────────────────────────
# QI_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# QI_AI_MODEL=meta/llama-3.1-8b-instruct
# QI_AI_BASE_URL=https://integrate.api.nvidia.com/v1
